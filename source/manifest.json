{
  "manifest_version": 3,
  "name": "Refined Bricklink",
  "version": "0.5.0",
  "description": "Toggleable UI features for bricklink.com",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.bricklink.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.bricklink.com/*"
      ],
      "js": [
        "registry.js",
        "features/wanted-list-hide.js",
        "features/reverse-wanted-list.js",
        "features/quantity-spacing.js",
        "features/wanted-list-change-tracker.js",
        "features/unsaved-changes-guard.js",
        "features/edit-summary-banner.js",
        "features/max-price-revert.js",
        "features/wanted-list-smart-filters.js",
        "features/wanted-list-download-buttons.js",
        "features/wanted-list-download-all.js",
        "features/wanted-list-merge.js",
        "main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
