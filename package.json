{
  "name": "refined-bricklink",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "bump": "node scripts/bump-version.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=no-auth",
    "test:e2e:auth": "playwright test --project=auth-setup --project=auth",
    "test:e2e:all": "playwright test",
    "test:all": "vitest run && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "jsdom": "^28.1.0",
    "vitest": "^3.0.0"
  }
}
